# ─────────────────────────────────────────────────────────────────────────────
# credit-scoring-risk/.env.example
#
# USO: cp .env.example .env  →  edita los valores  →  nunca subas .env a Git
# ─────────────────────────────────────────────────────────────────────────────

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8002
LOG_LEVEL=info

# ── CORS — orígenes permitidos (separados por coma, sin espacios) ─────────────
# ADVERTENCIA: En un sistema de scoring crediticio real, restringe al dominio
# específico de tu aplicación interna. NUNCA uses "*".
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Rate limiting ─────────────────────────────────────────────────────────────
# El scoring crediticio es costoso; limitar agresivamente evita abuso
RATE_LIMIT_PREDICT=5/minute

# ── Rutas de artefactos del modelo ───────────────────────────────────────────
MODEL_PATH=models/xgboost_best.joblib
PIPELINE_PATH=models/preprocessing_pipeline.joblib
SCALER_PATH=models/clustering_scaler.joblib
PCA_PATH=models/clustering_pca.joblib
KMEANS_PATH=models/kmeans_k4.joblib

# ── MLflow (opcional) ────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5002
