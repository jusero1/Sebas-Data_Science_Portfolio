# ─────────────────────────────────────────────────────────────────────────────
# time-series-forecast/.env.example
#
# USO: cp .env.example .env  →  edita los valores  →  nunca subas .env a Git
# ─────────────────────────────────────────────────────────────────────────────

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# ── CORS — orígenes permitidos (separados por coma, sin espacios) ─────────────
# En producción, reemplaza con el dominio real de tu frontend.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PREDICT=10/minute

# ── Modelos serializados ──────────────────────────────────────────────────────
# Rutas relativas al directorio del contenedor (/app/models/)
MODEL_PATH=models/lstm_best.h5
SCALER_PATH=models/scaler.joblib

# ── MLflow (opcional) ────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
