# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Plantilla de variables de entorno para el portafolio completo
#
# USO:
#   1. Copia este archivo: `cp .env.example .env`
#   2. Rellena los valores reales en tu .env local (nunca lo suba a Git)
#   3. El .env está en .gitignore; este .env.example SÍ se puede versionar
# ─────────────────────────────────────────────────────────────────────────────

# ── CORS ─────────────────────────────────────────────────────────────────────
# Lista de orígenes permitidos separados por coma (sin espacios).
# En producción sustituye por tu dominio real. NUNCA uses "*".
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Logging ───────────────────────────────────────────────────────────────────
# Opciones: debug | info | warning | error | critical
LOG_LEVEL=info

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Formato: "<número>/<ventana>" | Ejemplos: 10/minute, 100/hour
RATE_LIMIT_PREDICT=10/minute
RATE_LIMIT_DEFAULT=100/hour

# ── Proyecto 1: Time Series Forecast (puerto 8000) ───────────────────────────
TS_MODEL_PATH=models/lstm_best.h5
TS_SCALER_PATH=models/scaler.joblib

# ── Proyecto 2: Computer Vision (puerto 8001) ────────────────────────────────
CV_MODEL_PATH=models/resnet50_finetuned.h5
CV_IMG_SIZE=224
CV_THRESHOLD=0.5

# ── Proyecto 3: Credit Scoring (puerto 8002) ─────────────────────────────────
CS_MODEL_PATH=models/xgboost_best.joblib
CS_PIPELINE_PATH=models/preprocessing_pipeline.joblib
CS_SCALER_PATH=models/clustering_scaler.joblib
CS_PCA_PATH=models/clustering_pca.joblib
CS_KMEANS_PATH=models/kmeans_k4.joblib

# ── MLflow (opcional, para experimentos locales) ─────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
# MLFLOW_TRACKING_USERNAME=user       # Solo si usas MLflow con autenticación
# MLFLOW_TRACKING_PASSWORD=changeme   # Cambiar en producción

# ── Kaggle (necesario para descargar datasets automáticamente) ────────────────
# Obtén tus credenciales en https://www.kaggle.com/settings/account → API
# KAGGLE_USERNAME=tu_usuario
# KAGGLE_KEY=tu_api_key_aqui
