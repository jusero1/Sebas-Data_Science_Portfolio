__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.coverage
htmlcov/
dist/
build/

# Virtual environments
.venv/
venv/
env/

# MLflow artifacts
mlruns/
mlartifacts/

# IDE y OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Documentación
*.md
docs/

# Configuración de desarrollo
.pre-commit-config.yaml
pyproject.toml
