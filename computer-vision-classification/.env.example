# ─────────────────────────────────────────────────────────────────────────────
# computer-vision-classification/.env.example
#
# USO: cp .env.example .env  →  edita los valores  →  nunca subas .env a Git
# ─────────────────────────────────────────────────────────────────────────────

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8001
LOG_LEVEL=info

# ── CORS — orígenes permitidos (separados por coma, sin espacios) ─────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PREDICT=10/minute

# ── Configuración del modelo ──────────────────────────────────────────────────
MODEL_PATH=models/resnet50_finetuned.h5
IMG_SIZE=224
# Umbral de clasificación optimizado por F1 durante el entrenamiento
THRESHOLD=0.5

# ── Configuración de inferencia ───────────────────────────────────────────────
# Tamaño máximo de imagen aceptado (en MB)
MAX_FILE_SIZE_MB=5

# ── MLflow (opcional) ────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5001
